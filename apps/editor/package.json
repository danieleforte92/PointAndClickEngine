{
  "name": "@pointclick/editor",
  "version": "0.4.0-alpha.1",
  "private": true,
  "type": "commonjs",
  "main": ".vite/build/main.js",
  "config": {
    "forge": "./forge.config.ts"
  },
  "scripts": {
    "start": "electron-forge start",
    "build": "pnpm --filter @pointclick/player-web build && electron-forge package",
    "make": "electron-forge make",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@pointclick/authoring": "workspace:*",
    "@pointclick/contracts": "workspace:*",
    "@pointclick/project-io": "workspace:*",
    "@pointclick/ui-theme": "workspace:*",
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/shared-types": "^7.11.2",
    "@pointclick/player-web": "workspace:*",
    "@vitejs/plugin-react": "^4.5.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "electron": "^39.8.1",
    "lodash": "^4.17.21",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}

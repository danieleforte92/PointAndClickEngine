{
  "name": "point-and-click-engine",
  "version": "0.4.0-alpha.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.6.0",
  "engines": {
    "node": ">=22.17.0"
  },
  "pnpm": {
    "overrides": {
      "@electron/rebuild": "4.2.0",
      "shell-quote": "1.10.0",
      "tmp": "0.2.7"
    }
  },
  "scripts": {
    "dev": "concurrently -k -n player,editor -c cyan,magenta \"pnpm --filter @pointclick/player-web dev\" \"pnpm --filter @pointclick/editor start\"",
    "dev:player": "pnpm --filter @pointclick/player-web dev",
    "dev:editor": "pnpm --filter @pointclick/editor start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:packaged": "node scripts/test-packaged.mjs",
    "typecheck": "pnpm -r --if-present typecheck",
    "build": "pnpm -r --if-present build",
    "validate:sample": "tsx packages/cli/src/index.ts validate apps/sample-game/project",
    "validate:starter": "tsx packages/cli/src/index.ts validate apps/starter-game/project",
    "history": "tsx packages/cli/src/index.ts history",
    "project:diff": "tsx packages/cli/src/index.ts diff",
    "project:impact": "tsx packages/cli/src/index.ts impact",
    "export:web": "tsx packages/cli/src/index.ts export web",
    "validate:provenance": "node scripts/validate-provenance.mjs",
    "validate:provenance:strict": "node scripts/validate-provenance.mjs --strict",
    "check:release": "node scripts/check-release.mjs && node scripts/validate-provenance.mjs",
    "check:release:candidate": "node scripts/check-release.mjs --committed && node scripts/validate-provenance.mjs",
    "test:release-scripts": "node --test scripts/release-scripts.test.mjs",
    "verify:windows-package": "node scripts/verify-windows-package.mjs",
    "release:record": "node scripts/release-record.mjs",
    "check": "pnpm test && pnpm typecheck && pnpm validate:sample && pnpm validate:starter && pnpm build && pnpm check:release"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^26.1.1",
    "concurrently": "^9.2.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.7",
    "@vitest/coverage-v8": "^3.2.4"
  }
}
